<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 允许局域网 HTTP 明文流量（SD WebUI Forge 默认无 SSL） -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
